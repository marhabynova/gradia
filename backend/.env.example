# ==============================================================================
# GRADIA BACKEND - ENVIRONMENT VARIABLES
# ==============================================================================
# PERHATIAN: Isi nilai-nilai di bawah ini dengan kredensial nyata Anda sebelum deploy!

# --- DATABASE ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/gradia

# --- SECURITY (JWT) ---
JWT_SECRET=super-secret-gradia-key-do-not-use-in-prod

# --- GOOGLE SSO (OAUTH2) ---
# Dapatkan ini dari Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=ISI_DENGAN_GOOGLE_CLIENT_ID_ANDA.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ISI_DENGAN_GOOGLE_CLIENT_SECRET_ANDA

# --- SMTP EMAIL (MANDATORY FOR OTP) ---
# Jika pakai Gmail, pastikan 2-Step Verification aktif, lalu buat "App Password"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=email.kampus.anda@gmail.com
SMTP_PASSWORD=isi_dengan_app_password_16_digit_tanpa_spasi

# --- GEMINI AI (COST CONTROL) ---
GEMINI_API_KEY=ISI_DENGAN_GEMINI_API_KEY_ANDA

# --- PEMBAYARAN (QRIS MANUAL - TANPA POTONGAN GATEWAY) ---
# Nomor WhatsApp admin yang menerima konfirmasi pembayaran QRIS dari mahasiswa,
# lalu menyetujuinya secara manual di Admin Dashboard.
ADMIN_WA_NUMBER=6281234567890

# --- INFRASTRUCTURE (REDIS & OBSERVABILITY) ---
REDIS_URL=redis://localhost:6379/0
SENTRY_DSN=ISI_DENGAN_SENTRY_DSN_ANDA

# --- NOTIFICATION BOT ---
TELEGRAM_BOT_TOKEN=ISI_DENGAN_TELEGRAM_BOT_TOKEN_ANDA
TELEGRAM_CHAT_ID=ISI_DENGAN_TELEGRAM_CHAT_ID_ANDA
